        self.fit_time_ = perf_counter() - t0

        # 6) Сохраняем параметры.
        #    Здесь coef_ хранит все веса (включая интерсепт), чтобы совпасть с текущей реализацией.
        self.coef_ = <...>
        self.intercept_ = <...>

