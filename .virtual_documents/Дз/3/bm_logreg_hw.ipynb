        rng = np.random.default_rng(self.random_state)
        theta = rng.normal(0.0, 0.01, size=X_copy.shape[1])

        # 4) Сброс истории и счётчиков перед обучением
        self.history = []
        self.n_iter_ = 0
        self.n_epochs_ = 0
        self.samples_seen_ = 0

        # 5) Запускаем оптимизацию + меряем время
        t0 = perf_counter()
        if self.method == "gd":
